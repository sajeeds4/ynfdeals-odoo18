<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      YNF MFD v2 - Footer overhaul (Agent 3)

      Strategy for replacing the legacy ynf_storefront.ynf_footer:

      The legacy ynf_footer template (in views/templates.xml) inherits
      website.layout and replaces the page <footer/> with the old
      .ynf-mfd-footer-wrap markup. To swap in the new design without
      editing templates.xml, we inherit the legacy template itself and
      replace its outer <footer/> element wholesale with the v2 markup.

      Result: only ONE footer renders (the v2 one), the legacy
      .ynf-mfd-footer-* styles are not used, and templates.xml is
      untouched.
    -->
    <template id="ynf_footer_mfd2"
              inherit_id="ynf_storefront.ynf_footer"
              name="YNF MFD v2 Footer"
              priority="20">
        <xpath expr="//footer" position="replace">
            <footer class="ynf-mfd2-footer-wrap">
                <div class="ynf-mfd2-footer">

                    <!-- Brand + blurb + newsletter -->
                    <div class="ynf-mfd2-footer-brand">
                        <div class="ynf-mfd2-footer-logo">
                            <span class="ynf-mfd2-footer-logo-mark">Y</span>
                            <span class="ynf-mfd2-footer-wordmark">YNF Deals</span>
                        </div>
                        <p class="ynf-mfd2-footer-blurb">
                            Authentic Arabian &amp; niche fragrances at
                            live-auction prices. Catch us live on TikTok,
                            or shop the catalog anytime.
                        </p>

                        <form class="ynf-mfd2-footer-news"
                              data-ynf-newsletter="1"
                              onsubmit="return false;">
                            <label class="ynf-mfd2-footer-news-label"
                                   for="ynf_mfd2_newsletter_email">
                                Join the list
                            </label>
                            <div class="ynf-mfd2-footer-news-row">
                                <input type="email"
                                       id="ynf_mfd2_newsletter_email"
                                       class="ynf-mfd2-footer-news-input"
                                       name="email"
                                       placeholder="you@example.com"
                                       autocomplete="email"
                                       required="required"/>
                                <button type="submit"
                                        class="ynf-mfd2-footer-news-btn"
                                        data-ynf-newsletter-submit="1">
                                    Subscribe
                                </button>
                            </div>
                            <p class="ynf-mfd2-footer-news-msg"
                               data-ynf-newsletter-msg="1"
                               aria-live="polite"></p>
                        </form>
                    </div>

                    <!-- Link columns: stack on mobile, 3-up on desktop -->
                    <div class="ynf-mfd2-footer-cols">
                        <div class="ynf-mfd2-footer-col">
                            <h6 class="ynf-mfd2-footer-col-title">Shop</h6>
                            <a href="/shop?attribute_value=him">For Him</a>
                            <a href="/shop?attribute_value=her">For Her</a>
                            <a href="/shop">Unisex</a>
                            <a href="/shop">All houses</a>
                        </div>
                        <div class="ynf-mfd2-footer-col">
                            <h6 class="ynf-mfd2-footer-col-title">Help</h6>
                            <a href="/policy?topic=returns">Returns &amp; refunds</a>
                            <a href="/policy?topic=shipping">Shipping</a>
                            <a href="/policy?topic=privacy">Privacy &amp; cookies</a>
                            <a href="/policy?topic=terms">Terms</a>
                        </div>
                        <div class="ynf-mfd2-footer-col">
                            <h6 class="ynf-mfd2-footer-col-title">House</h6>
                            <a href="/policy?topic=about">About YNF</a>
                            <a href="/shop">Brands</a>
                            <a href="/live">Live auctions</a>
                            <a href="/contactus">Contact</a>
                        </div>
                    </div>

                    <!-- Diamond divider -->
                    <div class="ynf-mfd2-footer-divider" aria-hidden="true">
                        <span></span>
                        <span class="ynf-mfd2-footer-diamond">&#9670;</span>
                        <span></span>
                    </div>

                    <div class="ynf-mfd2-footer-copy">
                        © 2026 YNF Deals · ynfdeals.com
                    </div>

                    <div class="ynf-mfd2-footer-social">
                        <a href="https://www.instagram.com/ynfdeals"
                           rel="noopener noreferrer"
                           target="_blank">Instagram</a>
                        <span class="ynf-mfd2-footer-social-dot"/>
                        <a href="https://www.tiktok.com/@ynfdeals"
                           rel="noopener noreferrer"
                           target="_blank">TikTok</a>
                        <span class="ynf-mfd2-footer-social-dot"/>
                        <a href="https://www.youtube.com/@ynfdeals"
                           rel="noopener noreferrer"
                           target="_blank">YouTube</a>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>
