<?xml version="1.0" encoding="utf-8"?>
<!--
    YNF Deals - MFD v2 Product Detail page reskin.
    ============================================================
    Agent 9 deliverable.

    Override strategy
    .................
    We inherit website_sale.product with priority="20" so this template
    wins over the existing ynf_product_overrides (priority 16, the Odoo
    default) and ynf_product_notes (also priority 16) which live in
    views/templates.xml. Those legacy inherits stay in place but their
    xpath targets are still resolved against the same parent template, so
    they keep applying their tiny edits (a wrapper class + the basic notes
    block). Our higher-priority inherit runs after them and REPLACES the
    whole #product_detail_main row with the MFD v2 markup. We intentionally
    leave the surrounding scaffolding intact so:
      * the editor "drop building blocks here" structures stay editable,
      * the breadcrumb and search/pricelist row still render,
      * the SEO / itemprop metadata on #wrap remains in place,
      * the website.layout call is unmodified.

    Critical preserved form fields (per Odoo expectations):
      * form action="/shop/cart/update" method="POST"
      * csrf_token hidden input (t-nocache)
      * product_id hidden input bound to product_variant.id
      * product_template_id hidden input
      * product_category_id hidden input (when public_categ_ids present)
      * t-call="website_sale.variants" with original t-set params,
        which renders all ptal-{id} selects / radios used for
        product_template_attribute_value_ids.
      * Quantity input named "add_qty" (added in our quantity stepper).
      * The actual "Add to cart" trigger keeps id="add_to_cart" and the
        a-submit / js_check_product classes that the website_sale JS
        wires up for the unavailable-combination check + cart POST.

    Add to cart variants:
      * Main button (in form):     #add_to_cart .ynf-mfd2-product-add
      * Sticky bar clone (mobile): .ynf-mfd2-product-sticky-add. A sibling
        anchor id="add_to_cart_sticky" .a-submit rendered OUTSIDE the form;
        on click ynf_product.js dispatches a click on the original
        #add_to_cart so the existing website_sale handler does the work.
        This avoids double form submission and keeps variant validation.
============================================================ -->
<odoo>

    <!-- ============================================================
         Main override — replaces the product_detail_main row body.
         Priority 20 beats the default 16 of the legacy inherits.
         ============================================================ -->
    <template id="ynf_product_overrides_v2"
              inherit_id="website_sale.product"
              name="YNF MFD2 Product Detail"
              priority="20">

        <!-- Tag the wrap with our component root so the SCSS scope kicks in.
             We keep the existing class list and append ours. -->
        <xpath expr="//div[@id='wrap']" position="attributes">
            <attribute name="class" add="ynf-mfd2-product" separator=" "/>
        </xpath>

        <!-- Replace the inner row of #product_detail_main with our layout.
             Everything outside (the section wrapper, breadcrumb row, editor
             drop zones, oe_structure full description) stays as Odoo built it. -->
        <xpath expr="//div[@id='product_detail_main']" position="replace">
            <div class="row ynf-mfd2-product-row" id="product_detail_main"
                 data-name="Product Page"
                 t-att-data-image_width="website.product_page_image_width"
                 t-att-data-image_layout="website.product_page_image_layout">

                <t t-set="image_cols" t-value="website._get_product_page_proportions()"/>
                <t t-set="_brand" t-value="(product.name.split(' ')[0] if product.name else '').upper()"/>
                <t t-set="_inspired" t-value="product.x_ynf_inspired_by or False"/>
                <t t-set="_family" t-value="product.x_ynf_family or False"/>
                <t t-set="_img_url" t-value="product.x_ynf_image_url or False"/>
                <t t-set="_product_images" t-value="(product_variant._get_images() if product_variant else product._get_images())"/>
                <t t-set="_image_count" t-value="len(_product_images)"/>
                <t t-set="_ribbon" t-value="product_variant.sudo().variant_ribbon_id or product.sudo().website_ribbon_id"/>
                <t t-set="_rating_avg" t-value="product.rating_avg or 0"/>
                <t t-set="_rating_count" t-value="product.rating_count or 0"/>

                <!-- Single-column hero panel (we ignore image_cols on purpose;
                     the MFD v2 column is mobile-first capped at ~560px). -->
                <div class="col-12 ynf-mfd2-product-col">

                    <!-- ───────── Top: back-to-brand link ───────── -->
                    <a t-attf-href="/shop?search=#{_brand}" class="ynf-mfd2-product-backbrand">
                        <span class="ynf-mfd2-product-backbrand-arrow" aria-hidden="true">←</span>
                        <span class="ynf-mfd2-product-backbrand-name" t-esc="(_brand or 'All products').title()"/>
                    </a>

                    <!-- ───────── Gallery ─────────
                         If multi-image: horizontal scroll-snap, dots below.
                         If single image (or 0): one tile. We always emit
                         the SALE tag (when ribbon present) and wishlist heart. -->
                    <div class="ynf-mfd2-product-gallery" t-att-data-image-count="_image_count">
                        <div class="ynf-mfd2-product-gallery-frame">
                            <div class="ynf-mfd2-product-gallery-track"
                                 t-att-data-multi="'1' if _image_count > 1 else '0'">
                                <t t-if="_image_count > 0">
                                    <t t-foreach="_product_images" t-as="pimg">
                                        <div class="ynf-mfd2-product-gallery-slide" t-att-data-index="pimg_index">
                                            <img t-att-src="image_data_uri(pimg.image_1024) if pimg.image_1024 else ('/web/image/%s/%s/image_1024' % (pimg._name, pimg.id))"
                                                 t-att-alt="product.name"
                                                 loading="lazy"
                                                 class="ynf-mfd2-product-gallery-img"/>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="ynf-mfd2-product-gallery-slide" data-index="0">
                                        <img t-if="_img_url" t-att-src="_img_url" t-att-alt="product.name"
                                             class="ynf-mfd2-product-gallery-img" loading="lazy"/>
                                        <img t-else=""
                                             t-attf-src="/web/image/product.template/#{product.id}/image_1024"
                                             t-att-alt="product.name"
                                             class="ynf-mfd2-product-gallery-img" loading="lazy"/>
                                    </div>
                                </t>
                            </div>

                            <!-- Floating ribbon tag (SALE / NEW / etc.) -->
                            <t t-if="_ribbon and _ribbon.name">
                                <span class="ynf-mfd2-product-gallery-tag"
                                      t-attf-style="background-color: #{_ribbon.bg_color or '#c8862e'}; color: #{_ribbon.text_color or '#1a1410'};"
                                      t-esc="_ribbon.name"/>
                            </t>

                            <!-- Wishlist heart (visual + localStorage only) -->
                            <button type="button"
                                    class="ynf-mfd2-product-gallery-wish"
                                    aria-label="Add to wishlist"
                                    t-att-data-product-id="product.id">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
                                     stroke="currentColor" stroke-width="1.6"
                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                            </button>
                        </div>

                        <!-- Dots — JS sets one as .is-active on scroll-snap change -->
                        <t t-if="_image_count > 1">
                            <div class="ynf-mfd2-product-gallery-dots" role="tablist" aria-label="Product images">
                                <t t-foreach="_product_images" t-as="pimg2">
                                    <button type="button"
                                            t-attf-class="ynf-mfd2-product-gallery-dot #{'is-active' if pimg2_index == 0 else ''}"
                                            t-att-data-index="pimg2_index"
                                            t-att-aria-label="'Show image %d' % (pimg2_index + 1)"/>
                                </t>
                            </div>
                        </t>
                    </div>

                    <!-- ───────── Info head ───────── -->
                    <header class="ynf-mfd2-product-head">
                        <div class="ynf-mfd2-product-head-row">
                            <span class="ynf-mfd2-product-brand" t-esc="_brand"/>
                            <t t-if="is_view_active('website_sale.product_comment')">
                                <a href="#o_product_page_reviews"
                                   class="ynf-mfd2-product-rating"
                                   t-attf-aria-label="#{_rating_count} reviews, average #{_rating_avg}">
                                    <span class="ynf-mfd2-product-rating-stars" aria-hidden="true">
                                        <span t-attf-style="width: #{(_rating_avg / 5.0) * 100}%"/>
                                    </span>
                                    <span class="ynf-mfd2-product-rating-text"
                                          t-esc="'%.1f (%d)' % (_rating_avg, _rating_count)"/>
                                </a>
                            </t>
                        </div>

                        <h1 class="ynf-mfd2-product-name" itemprop="name" t-field="product.name">Product Name</h1>

                        <!-- Hidden SEO metadata Odoo expects -->
                        <t t-set="base_url" t-value="website.get_base_url()"/>
                        <span itemprop="url" style="display:none;" t-esc="base_url + product.website_url"/>
                        <span itemprop="image" style="display:none;" t-esc="base_url + website.image_url(product, 'image_1920')"/>

                        <t t-if="_family">
                            <div class="ynf-mfd2-product-family" t-esc="_family"/>
                        </t>

                        <t t-if="_inspired">
                            <div class="ynf-mfd2-product-inspired">
                                <span class="ynf-mfd2-product-inspired-spark" aria-hidden="true">✦</span>
                                <span class="ynf-mfd2-product-inspired-label">Inspired by</span>
                                <span class="ynf-mfd2-product-inspired-name" t-esc="_inspired"/>
                            </div>
                        </t>
                    </header>

                    <!-- ───────── Price + cart form ───────── -->
                    <form t-if="product._is_add_to_cart_possible()"
                          action="/shop/cart/update"
                          method="POST"
                          class="ynf-mfd2-product-form">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"
                               t-nocache="The csrf token must always be up to date."/>

                        <div class="js_product js_main_product ynf-mfd2-product-jsblock">
                            <!-- Keep Odoo's price renderer so all the discount /
                                 strike-through / VAT logic stays untouched. -->
                            <div class="ynf-mfd2-product-priceblock">
                                <t t-call="website_sale.product_price"/>
                                <small t-if="'base_unit_price' in combination_info"
                                       class="ms-1 text-muted o_base_unit_price_wrapper d-none"
                                       groups="website_sale.group_show_uom_price">
                                    <t t-call='website_sale.base_unit_price'/>
                                </small>
                            </div>

                            <!-- Description (oe_structure → editable) -->
                            <div t-field="product.description_ecommerce"
                                 class="oe_structure ynf-mfd2-product-desc"
                                 placeholder="A detailed, formatted description to promote your product on this page."/>

                            <!-- Variant select + hidden ids — required form fields. -->
                            <div class="ynf-mfd2-product-variants">
                                <t t-placeholder="select">
                                    <input type="hidden" class="product_id" name="product_id"
                                           t-att-value="product_variant.id"/>
                                    <input type="hidden" class="product_template_id" name="product_template_id"
                                           t-att-value="product.id"/>
                                    <input t-if="product.public_categ_ids.ids" type="hidden"
                                           class="product_category_id" name="product_category_id"
                                           t-att-value="product.public_categ_ids.ids[0]"/>
                                    <t t-call="website_sale.variants">
                                        <t t-set="ul_class" t-valuef="flex-column"/>
                                        <t t-set="parent_combination" t-value="None"/>
                                        <t t-set="combination" t-value="combination_info['combination']"/>
                                    </t>
                                </t>
                            </div>

                            <p t-if="True" class="css_not_available_msg alert alert-warning ynf-mfd2-product-unavail">
                                This combination does not exist.
                            </p>

                            <!-- ───────── Notes pyramid (component) ───────── -->
                            <div class="ynf-mfd2-product-notes-wrap">
                                <t t-call="ynf_storefront.ynf_mfd2_notes_pyramid">
                                    <t t-set="product" t-value="product"/>
                                </t>
                            </div>

                            <!-- ───────── Quantity stepper ───────── -->
                            <div class="ynf-mfd2-product-qty">
                                <label for="ynf_mfd2_product_qty" class="ynf-mfd2-product-qty-label">Quantity</label>
                                <div class="ynf-mfd2-product-qty-control" role="group" aria-label="Quantity">
                                    <button type="button"
                                            class="ynf-mfd2-product-qty-btn js-qty-dec"
                                            aria-label="Decrease quantity">−</button>
                                    <input id="ynf_mfd2_product_qty"
                                           type="number"
                                           class="ynf-mfd2-product-qty-input quantity"
                                           name="add_qty"
                                           min="1"
                                           value="1"
                                           inputmode="numeric"/>
                                    <button type="button"
                                            class="ynf-mfd2-product-qty-btn js-qty-inc"
                                            aria-label="Increase quantity">+</button>
                                </div>
                            </div>

                            <!-- ───────── Add to cart ───────── -->
                            <div id="o_wsale_cta_wrapper"
                                 class="ynf-mfd2-product-cta d-flex flex-wrap align-items-center">
                                <t t-set="hasQuantities" t-value="false"/>
                                <t t-set="hasBuyNow" t-value="false"/>
                                <t t-set="ctaSizeBig" t-value="not hasQuantities or not hasBuyNow"/>

                                <div id="add_to_cart_wrap"
                                     t-attf-class="{{'d-none' if combination_info['prevent_zero_price_sale'] else 'd-inline-flex'}} align-items-center w-100">
                                    <!-- KEEP id, KEEP a-submit + js_check_product so Odoo wires it up. -->
                                    <a data-animation-selector=".ynf-mfd2-product-gallery"
                                       role="button"
                                       id="add_to_cart"
                                       class="btn js_check_product a-submit ynf-mfd2-product-add ynf-mfd2-btn ynf-mfd2-btn-primary flex-grow-1"
                                       href="#">
                                        <span class="ynf-mfd2-btn-label">Add to bag</span>
                                    </a>
                                </div>
                                <div id="product_option_block" class="d-flex flex-wrap w-100"/>
                            </div>

                            <!-- Product tags (optional, keep upstream behavior) -->
                            <t t-if="is_view_active('website_sale.product_tags')"
                               t-call="website_sale.product_tags">
                                <t t-set="all_product_tags" t-value="product_variant.all_product_tag_ids"/>
                            </t>
                        </div>
                    </form>
                    <p t-elif="not product.active" class="alert alert-warning">This product is no longer available.</p>
                    <p t-else="" class="alert alert-warning">This product has no valid combination.</p>

                    <!-- ───────── Perks band ───────── -->
                    <section class="ynf-mfd2-product-perks" aria-label="Why buy from YNF Deals">
                        <div class="ynf-mfd2-product-perk">
                            <span class="ynf-mfd2-product-perk-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/>
                                    <path d="m9 12 2 2 4-4"/>
                                </svg>
                            </span>
                            <div class="ynf-mfd2-product-perk-text">
                                <div class="ynf-mfd2-product-perk-title">100% authentic</div>
                                <div class="ynf-mfd2-product-perk-sub">Sourced direct — never a tester or fake.</div>
                            </div>
                        </div>
                        <div class="ynf-mfd2-product-perk">
                            <span class="ynf-mfd2-product-perk-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 7h11v9H3z"/>
                                    <path d="M14 10h4l3 3v3h-7z"/>
                                    <circle cx="7" cy="18" r="1.5"/>
                                    <circle cx="17" cy="18" r="1.5"/>
                                </svg>
                            </span>
                            <div class="ynf-mfd2-product-perk-text">
                                <div class="ynf-mfd2-product-perk-title">Free shipping over $75</div>
                                <div class="ynf-mfd2-product-perk-sub">Tracked carriers, ships in 2 business days.</div>
                            </div>
                        </div>
                        <div class="ynf-mfd2-product-perk">
                            <span class="ynf-mfd2-product-perk-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M13 2 4 14h7l-2 8 10-13h-7l1-7z"/>
                                </svg>
                            </span>
                            <div class="ynf-mfd2-product-perk-text">
                                <div class="ynf-mfd2-product-perk-title">Live-auction prices</div>
                                <div class="ynf-mfd2-product-perk-sub">Catch it cheaper on our TikTok lives.</div>
                            </div>
                        </div>
                    </section>

                    <!-- Keep upstream accordion + product attributes + documents
                         so nothing the merchant configures gets lost. -->
                    <div class="ynf-mfd2-product-aftermatter">
                        <t t-call="website_sale.product_accordion"/>
                        <div t-if="not is_view_active('website_sale_comparison.accordion_specs_item')"
                             id="product_attributes_simple" class="ynf-mfd2-product-attrs">
                            <t t-set="single_value_attributes" t-value="product.valid_product_template_attribute_line_ids._prepare_single_value_for_display()"/>
                            <table t-attf-class="table table-sm text-muted {{'' if single_value_attributes else 'd-none'}}">
                                <t t-foreach="single_value_attributes" t-as="attribute">
                                    <tr>
                                        <td>
                                            <span t-field="attribute.name"/>:
                                            <t t-foreach="single_value_attributes[attribute]" t-as="ptal">
                                                <span t-field="ptal.product_template_value_ids._only_active().name"/><t t-if="not ptal_last">, </t>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                        <t t-set="product_documents" t-value="product.sudo().product_document_ids.filtered(lambda doc: doc.shown_on_product_page)"/>
                        <div id="product_documents" class="my-2" t-if="product_documents">
                            <h5>Documents</h5>
                            <t t-foreach="product_documents" t-as="document_sudo">
                                <t t-set="attachment_sudo" t-value="document_sudo.ir_attachment_id"/>
                                <t t-set="target" t-value="attachment_sudo.type == 'url' and '_blank' or '_self'"/>
                                <t t-set="icon" t-value="attachment_sudo.type == 'url' and 'fa-link' or 'fa-download'"/>
                                <div>
                                    <a t-att-href="'/shop/' + slug(product) + '/document/' + str(document_sudo.id)" t-att-target="target">
                                        <i t-att-class="'fa ' + icon"/>
                                        <t t-out="attachment_sudo.name"/>
                                    </a>
                                </div>
                            </t>
                        </div>
                        <div id="o_product_terms_and_share"
                             class="d-flex justify-content-between flex-column flex-md-row align-items-md-end gap-3 mb-3"/>
                    </div>

                    <!-- ───────── Related products rail ───────── -->
                    <t t-set="_related" t-value="(product.alternative_product_ids or (product.public_categ_ids and product.public_categ_ids[0].product_tmpl_ids.filtered(lambda p: p.id != product.id and p.is_published))[:8])"/>
                    <t t-if="_related">
                        <section class="ynf-mfd2-product-related" aria-labelledby="ynf_mfd2_related_head">
                            <header class="ynf-mfd2-section-head">
                                <div class="ynf-mfd2-section-head-text">
                                    <h2 id="ynf_mfd2_related_head" class="ynf-mfd2-section-head-title">You may also like</h2>
                                </div>
                            </header>
                            <t t-call="ynf_storefront.ynf_mfd2_rail">
                                <t t-foreach="_related[:8]" t-as="_rp">
                                    <t t-call="ynf_storefront.ynf_mfd2_card">
                                        <t t-set="product" t-value="_rp"/>
                                    </t>
                                </t>
                            </t>
                        </section>
                    </t>

                </div>
            </div>

            <!-- ───────── Sticky add-to-cart bar (mobile only) ─────────
                 Lives OUTSIDE the form on purpose. JS forwards taps to
                 #add_to_cart so we don't double-submit the cart POST and
                 we benefit from website_sale's combination check. -->
            <div class="ynf-mfd2-product-sticky d-md-none" aria-hidden="true" data-ynf-sticky-bar="1">
                <div class="ynf-mfd2-product-sticky-inner">
                    <div class="ynf-mfd2-product-sticky-meta">
                        <div class="ynf-mfd2-product-sticky-qty-line">Qty <span data-ynf-sticky-qty="1">1</span></div>
                        <div class="ynf-mfd2-product-sticky-price">
                            <span class="ynf-mfd2-price ynf-mfd2-price-md" data-ynf-sticky-price="1">
                                <span class="ynf-mfd2-price-sym">$</span><span class="ynf-mfd2-price-amount" t-esc="'%.2f' % float(combination_info.get('price', product.list_price or 0))"/>
                            </span>
                        </div>
                    </div>
                    <a href="#"
                       id="add_to_cart_sticky"
                       role="button"
                       class="ynf-mfd2-btn ynf-mfd2-btn-primary ynf-mfd2-product-sticky-add"
                       data-ynf-sticky-add="1">
                        <span class="ynf-mfd2-btn-label">Add to bag</span>
                    </a>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
