<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================ LAYOUT ============================ -->
    <!-- Announcement marquee + decorative butterfly on every page -->
    <template id="ynf_layout" inherit_id="website.layout" name="YNF Layout">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&amp;family=Inter:wght@400;500;600;700&amp;display=swap"/>
        </xpath>
        <!-- Hide Odoo's default header on the storefront — we render our own below -->
        <xpath expr="//header" position="attributes">
            <attribute name="class" add="ynf-hide-odoo-header" separator=" "/>
        </xpath>
        <xpath expr="//header" position="before">
            <div class="ynf-announce">
                <div class="ynf-marquee">
                    <t t-foreach="range(2)" t-as="loop">
                        <span>Free shipping over $75</span><span class="sep">✦</span>
                        <span>100% authentic guarantee</span><span class="sep">✦</span>
                        <span>Live auctions nightly · 8 PM ET</span><span class="sep">✦</span>
                        <span>New drops every week</span><span class="sep">✦</span>
                    </t>
                </div>
            </div>
            <!-- YNF custom header (desktop + mobile slim bar) -->
            <t t-set="ynf_cart_qty" t-value="(request.website.sale_get_order() and request.website.sale_get_order().cart_quantity) or 0"/>
            <t t-set="ynf_top_menus" t-value="request.website.menu_id and request.website.menu_id.child_id or []"/>
            <header class="ynf-header" role="banner">
                <div class="ynf-header-inner">
                    <button type="button" class="ynf-header-burger d-md-none"
                            aria-label="Open menu" aria-controls="ynf-mobile-drawer"
                            onclick="document.getElementById('ynf-mobile-drawer').classList.add('is-open')">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
                    </button>
                    <a href="/" class="ynf-header-brand" aria-label="YNF Deals home">
                        <span class="ynf-header-logo"><span>Y</span></span>
                        <span class="ynf-header-brandname">YNF DEALS</span>
                    </a>
                    <nav class="ynf-header-nav d-none d-md-flex" aria-label="Primary">
                        <t t-foreach="ynf_top_menus" t-as="m">
                            <a t-att-href="m.url"
                               t-attf-class="ynf-header-link #{request.httprequest.path == m.url and 'is-active' or ''}"
                               t-esc="m.name"/>
                        </t>
                    </nav>
                    <div class="ynf-header-actions">
                        <button type="button" class="ynf-header-iconbtn ynf-header-search-toggle"
                                aria-label="Search"
                                onclick="document.getElementById('ynf-search-overlay').classList.add('is-open'); setTimeout(function(){var i=document.getElementById('ynf-search-input'); if(i) i.focus();}, 50);">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
                        </button>
                        <a href="/my" class="ynf-header-iconbtn d-none d-md-inline-flex" aria-label="Account">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
                        </a>
                        <a href="/shop/cart" class="ynf-header-iconbtn ynf-header-cart" aria-label="Cart">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1.5 11h-11z"/><path d="M9 8a3 3 0 016 0"/></svg>
                            <span t-if="ynf_cart_qty &gt; 0" class="ynf-header-cart-badge" t-esc="ynf_cart_qty"/>
                        </a>
                    </div>
                </div>
            </header>
            <!-- Mobile slide-in drawer (nav links) -->
            <div class="ynf-mobile-drawer d-md-none" id="ynf-mobile-drawer" role="dialog" aria-label="Menu" aria-hidden="true">
                <div class="ynf-mobile-drawer-backdrop"
                     onclick="document.getElementById('ynf-mobile-drawer').classList.remove('is-open')"/>
                <aside class="ynf-mobile-drawer-panel">
                    <div class="ynf-mobile-drawer-head">
                        <span class="ynf-header-brandname">YNF DEALS</span>
                        <button type="button" class="ynf-mobile-drawer-close" aria-label="Close menu"
                                onclick="document.getElementById('ynf-mobile-drawer').classList.remove('is-open')">
                            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
                        </button>
                    </div>
                    <nav class="ynf-mobile-drawer-nav" aria-label="Mobile menu">
                        <t t-foreach="ynf_top_menus" t-as="m">
                            <a t-att-href="m.url" t-esc="m.name"/>
                        </t>
                        <a href="/my" class="ynf-mobile-drawer-divider">My Account</a>
                        <a href="/my/help">Help &amp; disputes</a>
                        <a href="/policy">Policies</a>
                    </nav>
                </aside>
            </div>
            <!-- Search overlay (shared desktop + mobile) -->
            <div class="ynf-search-overlay" id="ynf-search-overlay" role="dialog" aria-label="Search">
                <div class="ynf-search-overlay-backdrop"
                     onclick="document.getElementById('ynf-search-overlay').classList.remove('is-open')"/>
                <form class="ynf-search-overlay-form" action="/shop" method="get" role="search">
                    <button type="button" class="ynf-search-overlay-close" aria-label="Close search"
                            onclick="document.getElementById('ynf-search-overlay').classList.remove('is-open')">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
                    </button>
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ynf-search-overlay-icon"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
                    <input type="search" name="search" id="ynf-search-input"
                           placeholder="Search fragrances, brands, notes…"
                           autocomplete="off"/>
                    <button type="submit" class="ynf-search-overlay-go">Search</button>
                </form>
            </div>
        </xpath>
        <xpath expr="//div[@id='wrapwrap']" position="inside">
            <!-- Mobile bottom tab bar (sticky, hidden on md+) -->
            <nav class="ynf-mfd-tabbar d-md-none" aria-label="Primary mobile nav">
                <a t-attf-href="/" t-attf-class="ynf-mfd-tab #{request.httprequest.path == '/' and 'is-active' or ''}">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
                    <span>Home</span>
                </a>
                <a t-attf-href="/shop" t-attf-class="ynf-mfd-tab #{request.httprequest.path.startswith('/shop') and not request.httprequest.path.startswith('/shop/cart') and 'is-active' or ''}">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1.5-5h15L21 9"/><path d="M3 9h18v11H3z"/></svg>
                    <span>Shop</span>
                </a>
                <a t-attf-href="/live" t-attf-class="ynf-mfd-tab ynf-mfd-tab-live #{request.httprequest.path == '/live' and 'is-active' or ''}">
                    <span class="ynf-mfd-tab-live-pill" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3" fill="currentColor"/></svg>
                        <span class="ynf-mfd-tab-live-dot"/>
                    </span>
                    <span>Live</span>
                </a>
                <a t-attf-href="/shop/cart" t-attf-class="ynf-mfd-tab #{request.httprequest.path.startswith('/shop/cart') and 'is-active' or ''}">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1.5 11h-11z"/><path d="M9 8a3 3 0 016 0"/></svg>
                    <span>Bag</span>
                </a>
                <a t-attf-href="/my" t-attf-class="ynf-mfd-tab #{request.httprequest.path.startswith('/my') and 'is-active' or ''}">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
                    <span>You</span>
                </a>
            </nav>
            <!-- Cookie consent banner — JS toggles class=is-visible after checking localStorage -->
            <div class="ynf-cookie" id="ynf-cookie-banner" role="dialog" aria-label="Cookies notice">
                <div class="ynf-cookie-title">We value your privacy</div>
                <div class="ynf-cookie-body">
                    We use cookies to keep your bag, remember preferences, and improve the store.
                    <a href="/policy?topic=privacy" class="ynf-cookie-learn">Learn more</a>.
                </div>
                <div class="ynf-cookie-actions">
                    <button type="button" class="ynf-cookie-btn ynf-cookie-btn-accept" data-cookie="all">Accept all</button>
                    <button type="button" class="ynf-cookie-btn ynf-cookie-btn-essential" data-cookie="essential">Essential only</button>
                </div>
            </div>
            <!-- Add-to-bag toast — dynamically populated by ynf_theme.js -->
            <div class="ynf-toast" id="ynf-toast" role="status" aria-live="polite">
                <span class="ynf-toast-icon" aria-hidden="true">✓</span>
                <div class="ynf-toast-body">
                    <div class="ynf-toast-eyebrow">Added to bag</div>
                    <div class="ynf-toast-name" id="ynf-toast-name">—</div>
                </div>
                <a href="/shop/cart" class="ynf-toast-cta">View bag</a>
            </div>
            <div class="ynf-butterfly" aria-hidden="true">
                <svg viewBox="0 0 48 46" width="34" height="34">
                    <g class="ynf-bf-l">
                        <path d="M24 16 C 15 4 3 6 4 14 C 4.5 19 8 22 15 22 C 20 22 23 20 24 18 Z" fill="#241a12"/>
                        <path d="M24 19 C 18 21 10 24 13 32 C 16 37 22 34 24 24 Z" fill="#241a12"/>
                        <path d="M23 16.5 C 16 7 6 8.6 6.6 14.2 C 7 18 10 20 15 20 C 19 20 21.5 18.5 23 17 Z" fill="#d39a3e"/>
                        <path d="M23 20.5 C 18 22 12.5 25 15 31 C 17 35 21 32 23 24 Z" fill="#cf8f33"/>
                        <circle cx="6.5" cy="12.2" r="0.85" fill="#fff7ea"/><circle cx="5.4" cy="15" r="0.8" fill="#fff7ea"/><circle cx="9" cy="18.4" r="0.75" fill="#fff7ea"/>
                    </g>
                    <g class="ynf-bf-r">
                        <path d="M24 16 C 33 4 45 6 44 14 C 43.5 19 40 22 33 22 C 28 22 25 20 24 18 Z" fill="#241a12"/>
                        <path d="M24 19 C 30 21 38 24 35 32 C 32 37 26 34 24 24 Z" fill="#241a12"/>
                        <path d="M25 16.5 C 32 7 42 8.6 41.4 14.2 C 41 18 38 20 33 20 C 29 20 26.5 18.5 25 17 Z" fill="#d39a3e"/>
                        <path d="M25 20.5 C 30 22 35.5 25 33 31 C 31 35 27 32 25 24 Z" fill="#cf8f33"/>
                        <circle cx="41.5" cy="12.2" r="0.85" fill="#fff7ea"/><circle cx="42.6" cy="15" r="0.8" fill="#fff7ea"/><circle cx="39" cy="18.4" r="0.75" fill="#fff7ea"/>
                    </g>
                    <ellipse cx="24" cy="23" rx="1.5" ry="9.5" fill="#1d150e"/>
                    <circle cx="24" cy="12.6" r="2" fill="#1d150e"/>
                    <path d="M24 11 C 22 7 20.5 5.6 18.8 4.8 M24 11 C 26 7 27.5 5.6 29.2 4.8" stroke="#1d150e" stroke-width="0.8" fill="none" stroke-linecap="round"/>
                </svg>
            </div>
        </xpath>
    </template>

    <!-- Reusable product card (designer's spec — uses .oe_product so the shop catalog
         and homepage rails share one card style). The card form lets visitors add
         straight to the bag without leaving the page. -->
    <template id="ynf_product_card" name="YNF Product Card">
        <div class="oe_product ynf-rev">
            <a t-attf-href="/shop/product/#{slug(product)}" class="oe_product_image oe_product_image_link">
                <img t-if="product.x_ynf_image_url" t-att-src="product.x_ynf_image_url" t-att-alt="product.name" class="img img-fluid" loading="lazy"/>
                <img t-else="t-else" t-attf-src="/web/image/product.template/#{product.id}/image_512" t-att-alt="product.name" class="img img-fluid" loading="lazy"/>
            </a>
            <div class="o_wsale_product_information">
                <h6 class="o_wsale_products_item_title">
                    <a t-attf-href="/shop/product/#{slug(product)}" t-field="product.name"/>
                </h6>
                <span class="ynf-inspired" t-if="product.x_ynf_inspired_by">✦ Inspired by <t t-esc="product.x_ynf_inspired_by"/></span>
                <div class="product_price">
                    <span t-field="product.list_price" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                </div>
            </div>
        </div>
    </template>

    <!-- ============================ HOMEPAGE ============================ -->
    <!-- Curated homepage at /ynf-home — Lattafa-inspired design per YNF Deals.html.
         Hero · Live strip · Collections · Bestsellers · Shop by mood · Under $30 ·
         New arrivals · Curated bundles · House spotlight · Editorial band ·
         Fragrance finder · Testimonials · Stats · Authenticity · Drop alert. -->
    <template id="ynf_homepage" name="YNF Homepage">
        <t t-call="website.layout">
            <!-- Only surface products that actually have a photo so the homepage isn't a wall of placeholders. -->
            <t t-set="pub" t-value="[('sale_ok','=',True),('is_published','=',True),'|',('image_1920','!=',False),('x_ynf_image_url','!=',False)]"/>
            <t t-set="newest" t-value="request.env['product.template'].sudo().search(pub, limit=8, order='create_date desc')"/>
            <t t-set="cheap" t-value="request.env['product.template'].sudo().search(pub + [('list_price','&lt;=',31)], limit=8)"/>
            <t t-set="bundle_src" t-value="request.env['product.template'].sudo().search(pub, limit=9)"/>
            <div id="wrap" class="ynf-homepage">

                <!-- HERO -->
                <section class="ynf-wrap" style="margin-top:18px;">
                    <div class="ynf-hero ynf-rev">
                        <span class="ynf-hero-eyebrow">Authentic Fragrances · Live Auctions</span>
                        <h1>Discover your <em>signature</em> scent.</h1>
                        <p class="lead">Hand-picked Arabian &amp; niche houses at live-auction prices. Shipped fast, 100% authentic.</p>
                        <div class="ynf-hero-cta">
                            <a href="/shop" class="btn btn-primary">Shop fragrances</a>
                            <a href="/live" class="btn btn-outline-primary">Watch live</a>
                        </div>
                    </div>
                </section>

                <!-- LIVE STRIP -->
                <section class="ynf-wrap" style="margin-top:30px;">
                    <a href="/live" class="ynf-live-strip ynf-rev d-block text-decoration-none">
                        <span class="ynf-eyebrow-gold">● Live tonight · 8 PM ET · TikTok</span>
                        <h2 class="mt-2">Auction night — steals start at <span style="color:#c9a961;">$1</span>.</h2>
                    </a>
                </section>

                <!-- COLLECTIONS -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Shop by</span><h2>Collections</h2></div>
                    <div class="ynf-coll-grid ynf-rev">
                        <a href="/shop?attribute_value=him" class="ynf-coll-card"><span class="ynf-coll-overlay"><h3>For Him</h3></span></a>
                        <a href="/shop?attribute_value=her" class="ynf-coll-card"><span class="ynf-coll-overlay"><h3>For Her</h3></span></a>
                        <a href="/shop" class="ynf-coll-card"><span class="ynf-coll-overlay"><h3>Unisex</h3></span></a>
                    </div>
                </section>

                <!-- BESTSELLERS -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Currently trending</span><h2>Bestsellers</h2></div>
                    <div class="row g-3" id="products_grid">
                        <t t-foreach="newest" t-as="product">
                            <div class="col-6 col-md-3"><t t-call="ynf_storefront.ynf_product_card"/></div>
                        </t>
                    </div>
                    <div class="text-center mt-4"><a href="/shop" class="btn btn-outline-primary">View all products</a></div>
                </section>

                <!-- SHOP BY MOOD -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Shop by mood</span><h2>What are you in the mood for?</h2></div>
                    <div class="ynf-moods ynf-rev">
                        <a href="/shop?family=warm" class="ynf-mood-card"><span class="ynf-mood-ic">✦</span><h3>Warm &amp; Sweet</h3><p>Gourmand · amber · vanilla</p></a>
                        <a href="/shop?family=fresh" class="ynf-mood-card"><span class="ynf-mood-ic">❋</span><h3>Fresh &amp; Clean</h3><p>Aquatic · citrus · cool</p></a>
                        <a href="/shop?family=oud" class="ynf-mood-card"><span class="ynf-mood-ic">◆</span><h3>Woody &amp; Oud</h3><p>Smoky · resinous · bold</p></a>
                        <a href="/shop?family=floral" class="ynf-mood-card"><span class="ynf-mood-ic">✿</span><h3>Floral</h3><p>Rose · jasmine · blossom</p></a>
                    </div>
                </section>

                <!-- UNDER $30 -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Smell luxury for less</span><h2>Under $30</h2></div>
                    <div class="ynf-rail">
                        <t t-foreach="cheap" t-as="product"><t t-call="ynf_storefront.ynf_product_card"/></t>
                    </div>
                </section>

                <!-- NEW ARRIVALS -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Just dropped</span><h2>New arrivals</h2></div>
                    <div class="ynf-rail">
                        <t t-foreach="newest" t-as="product"><t t-call="ynf_storefront.ynf_product_card"/></t>
                    </div>
                </section>

                <!-- CURATED BUNDLES -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Discovery sets</span><h2>Curated bundles</h2></div>
                    <div class="ynf-rail">
                        <t t-foreach="[('Crowd-Pleasers Trio', 0), ('Dupe Starter Set', 3), ('For Her Edit', 6)]" t-as="b">
                            <t t-set="items" t-value="bundle_src[b[1]:b[1]+3]"/>
                            <a href="/shop" class="ynf-bundle ynf-rev">
                                <div class="ynf-bundle-imgs">
                                    <t t-foreach="items" t-as="bp"><img t-attf-src="/web/image/product.template/#{bp.id}/image_256" t-att-alt="bp.name"/></t>
                                </div>
                                <div class="ynf-bundle-b">
                                    <span class="save">Save 15%</span>
                                    <h3><t t-esc="b[0]"/></h3>
                                    <t t-set="full" t-value="sum(items.mapped('list_price'))"/>
                                    <div>$<span class="price" t-esc="round(full*0.85)"/><span class="strike">$<t t-esc="round(full,2)"/></span></div>
                                </div>
                            </a>
                        </t>
                    </div>
                </section>

                <!-- HOUSE SPOTLIGHT -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-spotlight ynf-rev">
                        <span class="ynf-eyebrow-gold">House spotlight</span>
                        <h2>Lattafa</h2>
                        <p>The house behind Khamrah, Asad and Yara — bold, affordable Arabian perfumery that punches far above its price.</p>
                        <a href="/shop?brand=lattafa" class="btn btn-primary mt-2">Shop Lattafa</a>
                    </div>
                </section>

                <!-- EDITORIAL IMAGE BAND (images editable in Website editor) -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-editorial ynf-rev">
                        <img class="ynf-edslot" src="/web/image/website.s_banner_default_image" alt="Our house"/>
                        <div class="ynf-ed-cap"><span class="ynf-eyebrow-gold">Our house</span><h2>Perfumery, the old-world way.</h2></div>
                    </div>
                    <p class="ynf-quote">"We hunt down the bottles worth wearing — and price them so you can actually own them."</p>
                    <div class="ynf-edgrid ynf-rev">
                        <img class="ynf-edslot" src="/web/image/website.s_banner_default_image" alt="Atelier"/>
                        <img class="ynf-edslot" src="/web/image/website.s_banner_default_image" alt="Bottles"/>
                    </div>
                </section>

                <!-- FRAGRANCE FINDER -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <a href="/shop" class="ynf-quizcard ynf-rev d-block text-decoration-none">
                        <h2>Find your <em>signature</em></h2>
                        <p class="text-muted">Answer 4 quick questions and we'll match you to your next scent.</p>
                        <span class="btn btn-outline-primary">Start the quiz →</span>
                    </a>
                </section>

                <!-- TESTIMONIALS -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">Loved by thousands</span><h2>What buyers say</h2></div>
                    <div class="ynf-rail">
                        <t t-foreach="[('Khamrah is unreal for the price — compliments every single time.', 'Ayesha K.'), ('Won Hawas on a live for $14. 100% authentic, shipped in two days.', 'Marcus T.'), ('Yara smells expensive and lasts all day. Obsessed.', 'Dana R.')]" t-as="rev">
                            <div class="ynf-testi ynf-rev">
                                <div style="color:#a07f3a;">★★★★★</div>
                                <p class="q">"<t t-esc="rev[0]"/>"</p>
                                <div class="who"><t t-esc="rev[1]"/></div>
                                <div class="verif">✓ Verified buyer</div>
                            </div>
                        </t>
                    </div>
                </section>

                <!-- STATS -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-stats ynf-rev">
                        <div><div class="n ynf-count" data-to="12000" data-suffix="+">0</div><div class="l">Bottles shipped</div></div>
                        <div><div class="n ynf-count" data-to="60" data-suffix="+">0</div><div class="l">Fragrances</div></div>
                        <div><div class="n">4.8★</div><div class="l">Avg rating</div></div>
                        <div><div class="n ynf-count" data-to="4" data-suffix="">0</div><div class="l">Houses</div></div>
                    </div>
                </section>

                <!-- AUTHENTICITY -->
                <section class="ynf-wrap" style="margin-top:48px;">
                    <div class="ynf-auth ynf-rev">
                        <div class="text-center mb-3"><span class="ynf-eyebrow-gold">The YNF promise</span><h2 style="font-family:var(--ynf-font-serif,'Cormorant Garamond',serif);color:#fff;">100% authentic, always</h2></div>
                        <div class="row"><i>✦</i><div><h4>Sourced direct</h4><p>From brands &amp; authorized distributors — never testers or fakes.</p></div></div>
                        <div class="row"><i>✦</i><div><h4>Batch-code verified</h4><p>Every bottle checks out, or we refund you in full.</p></div></div>
                        <div class="row"><i>✦</i><div><h4>Fast, tracked shipping</h4><p>Ships within 2 business days, free over $75.</p></div></div>
                    </div>
                </section>

                <!-- DROP ALERT -->
                <section class="ynf-wrap" style="margin-top:48px; margin-bottom:48px;">
                    <div class="ynf-dropalert ynf-rev">
                        <h2>Never miss a drop</h2>
                        <p style="opacity:.85;">Get a heads-up before every live auction and new arrival.</p>
                        <form>
                            <input type="email" placeholder="Your email" required="required"/>
                            <button type="submit">Notify me</button>
                        </form>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="ynf_homepage_page" model="website.page">
        <field name="name">Home</field>
        <field name="url">/ynf-home</field>
        <field name="view_id" ref="ynf_homepage"/>
        <field name="website_published">True</field>
    </record>

    <!-- ============================ SHOP ============================ -->
    <template id="ynf_products_item_inspired" inherit_id="website_sale.products_item" name="YNF Inspired chip">
        <xpath expr="//div[hasclass('o_wsale_product_information')]//div[hasclass('product_price')]" position="before">
            <span class="ynf-inspired" t-if="product.x_ynf_inspired_by">✦ Inspired by <t t-esc="product.x_ynf_inspired_by"/></span>
        </xpath>
    </template>

    <!-- ============================ PRODUCT ============================ -->
    <template id="ynf_product_overrides" inherit_id="website_sale.product" name="YNF Product wrapper">
        <xpath expr="//div[@id='wrap']" position="attributes">
            <attribute name="class" add="ynf-product-detail" separator=" "/>
        </xpath>
    </template>
    <template id="ynf_product_notes" inherit_id="website_sale.product" name="YNF Notes Pyramid">
        <xpath expr="//div[@id='product_details']" position="inside">
            <div class="ynf-notes" t-if="product.x_ynf_note_top or product.x_ynf_note_mid or product.x_ynf_note_base">
                <div class="ynf-notes-row" t-if="product.x_ynf_note_top"><span class="label">Top</span><span class="val" t-esc="product.x_ynf_note_top"/></div>
                <div class="ynf-notes-row" t-if="product.x_ynf_note_mid"><span class="label">Heart</span><span class="val" t-esc="product.x_ynf_note_mid"/></div>
                <div class="ynf-notes-row" t-if="product.x_ynf_note_base"><span class="label">Base</span><span class="val" t-esc="product.x_ynf_note_base"/></div>
            </div>
        </xpath>
    </template>

    <!-- ============================ LIVE ============================ -->
    <template id="ynf_live_page" name="YNF Live">
        <t t-call="website.layout">
            <div id="wrap" class="ynf-live-page">
                <section class="ynf-wrap" style="margin-top:18px;">
                    <div class="ynf-spotlight ynf-rev" style="background:linear-gradient(150deg,#6b1f23,#2a0f12);">
                        <span class="ynf-eyebrow-gold">● Live tonight · 8 PM ET</span>
                        <h2>Auction night on <span style="color:#c9a961;">TikTok Live</span></h2>
                        <p>Bids open at $1. Win authentic bottles for a fraction of retail — shipped straight to your door.</p>
                        <a href="/shop" class="btn btn-primary mt-2">Shop catalog</a>
                    </div>
                </section>
                <section class="ynf-wrap" style="margin-top:40px; margin-bottom:48px;">
                    <div class="ynf-section-title ynf-rev"><span class="eyebrow">How it works</span><h2>Bid, win, we ship</h2></div>
                </section>
            </div>
        </t>
    </template>
    <record id="ynf_live_page_rec" model="website.page">
        <field name="name">Live</field>
        <field name="url">/live</field>
        <field name="view_id" ref="ynf_live_page"/>
        <field name="website_published">True</field>
    </record>
    <!-- /live menu is created in post_init by _ynf_setup_menus (see models/website_menu_setup.py) -->

    <!-- Policies & help page -->
    <template id="ynf_policy_page" name="YNF Policies">
        <t t-call="website.layout">
            <div id="wrap" class="ynf-policy-page ynf-mfd">
                <section class="ynf-mfd-wrap">
                    <div class="ynf-policy-head">
                        <span class="ynf-mfd-eyebrow-sm">SUPPORT</span>
                        <h1 class="ynf-mfd-h2">Help &amp; policies</h1>
                        <p class="ynf-policy-intro">Quick answers — tap any section to expand.</p>
                    </div>
                    <div class="ynf-policy-list">
                        <details class="ynf-policy-item">
                            <summary>Returns &amp; refunds</summary>
                            <div class="ynf-policy-body">
                                <p>Unopened items can be returned within <strong>30 days</strong> of delivery for a full refund of the item price.</p>
                                <p>Opened/used fragrances are non-returnable for hygiene reasons.</p>
                                <p><strong>Live auction wins are final sale</strong> — they're sold at a steep discount and we can't restock them.</p>
                                <p>To start a return, email <a href="mailto:hello@ynfdeals.com">hello@ynfdeals.com</a> with your order number.</p>
                            </div>
                        </details>
                        <details class="ynf-policy-item">
                            <summary>Shipping</summary>
                            <div class="ynf-policy-body">
                                <p><strong>Free shipping</strong> on orders over $75 (US only). Otherwise $6.95 flat.</p>
                                <p>Orders ship within <strong>2 business days</strong> from our New Jersey warehouse via USPS or UPS Ground with tracking.</p>
                                <p>Live-auction wins ship together at the end of each show week — typically Mon/Tue after the prior Sunday's auction.</p>
                            </div>
                        </details>
                        <details class="ynf-policy-item">
                            <summary>Authenticity guarantee</summary>
                            <div class="ynf-policy-body">
                                <p>Every bottle is sourced direct from the brand or an authorized distributor. We <strong>never sell testers or unboxed product</strong> as new.</p>
                                <p>Each shipment is batch-code verified. If you ever doubt a bottle, send a photo of the batch code to <a href="mailto:hello@ynfdeals.com">hello@ynfdeals.com</a> and we'll check it against the manufacturer's records — or refund you in full.</p>
                            </div>
                        </details>
                        <details class="ynf-policy-item" id="privacy">
                            <summary>Privacy &amp; cookies</summary>
                            <div class="ynf-policy-body">
                                <p>We use cookies to keep your shopping bag, remember preferences, and improve the store. We <strong>do not sell your data</strong>.</p>
                                <p>Essential cookies are required for the site to function. Analytics cookies are optional — you can decline them in the consent banner.</p>
                                <p>For account/order data we follow standard PCI-DSS handling via our payment processor. Email <a href="mailto:hello@ynfdeals.com">hello@ynfdeals.com</a> for a copy or deletion of your data.</p>
                            </div>
                        </details>
                        <details class="ynf-policy-item">
                            <summary>Terms of service</summary>
                            <div class="ynf-policy-body">
                                <p>By placing an order you agree that all listings, prices, and stock are subject to change without notice and that we may cancel any order at any time prior to shipment.</p>
                                <p>Live-auction wins are governed by the platform rules on TikTok at the time of the auction.</p>
                                <p>Promotional discounts cannot be combined with auction pricing.</p>
                            </div>
                        </details>
                        <details class="ynf-policy-item">
                            <summary>Contact</summary>
                            <div class="ynf-policy-body">
                                <p>Email — <a href="mailto:hello@ynfdeals.com">hello@ynfdeals.com</a></p>
                                <p>Live shows — <a href="https://www.tiktok.com/@ynfdeals" target="_blank" rel="noopener">@ynfdeals on TikTok</a></p>
                                <p>Mailing — YNF Deals, New Jersey, USA</p>
                            </div>
                        </details>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <record id="ynf_policy_page_rec" model="website.page">
        <field name="name">Policies</field>
        <field name="url">/policy</field>
        <field name="view_id" ref="ynf_policy_page"/>
        <field name="website_published">True</field>
    </record>

