<?xml version="1.0" encoding="utf-8"?>
<!--
    YNF MFD v2 - Shop catalog reskin (Agent 8)

    Strategy:
      The default /shop page is rendered by `website_sale.products`. That
      template wraps its body in `<div id="wrap" class="js_sale o_wsale_products_page">`.
      We inherit that template and REPLACE the inner #wrap with our own
      MFD v2 grid so we keep the controller (with `products`, `bins`, `keep`,
      `pager`, `attrib_set`, `search`, etc. in scope) but ditch the legacy
      Bootstrap layout entirely.

      Filters: gender + brand + family are sourced from the URL query string
      (request.params) using simple keys we control:
        ?ynf_gender=men   -> domain('x_ynf_gender','ilike',value)
        ?ynf_brand=lattafa-> domain('x_ynf_brand','ilike',value)
        ?ynf_family=oud   -> domain('x_ynf_family','ilike',value)

      We re-fetch a filtered slice of `products` ourselves (capped at ppg,
      with offset from the controller). This keeps Odoo's pager working as
      long as we don't change the total count drastically; if there is a
      mismatch we fall back to the controller's bins.

      Sort uses Odoo's native ?order= param which the controller honours.
-->
<odoo>

    <!-- =====================================================================
         Shop catalog grid
         ===================================================================== -->
    <template id="ynf_mfd2_shop"
              inherit_id="website_sale.products"
              name="YNF MFD v2 Shop Catalog"
              priority="20">

        <!-- Replace the entire #wrap of website_sale.products with our grid. -->
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="js_sale o_wsale_products_page ynf-mfd2-shop">

                <!-- ============ DATA RESOLUTION ============ -->
                <t t-set="ynf_gender_raw" t-value="(request.params.get('ynf_gender') or '').strip()"/>
                <t t-set="ynf_brand_raw"  t-value="(request.params.get('ynf_brand') or '').strip()"/>
                <t t-set="ynf_family_raw" t-value="(request.params.get('ynf_family') or '').strip()"/>
                <t t-set="ynf_sort_raw"   t-value="(request.params.get('order') or '').strip()"/>

                <!-- Build the YNF-aware product list. If any of our chip filters
                     are active, re-query so the grid reflects them. Otherwise
                     reuse the controller-supplied `products`. -->
                <t t-set="ynf_filter_active"
                   t-value="bool(ynf_gender_raw or ynf_brand_raw or ynf_family_raw)"/>
                <t t-if="ynf_filter_active">
                    <t t-set="ynf_domain"
                       t-value="[('is_published','=', True), ('sale_ok','=', True)]"/>
                    <t t-if="ynf_gender_raw">
                        <t t-set="ynf_domain"
                           t-value="ynf_domain + [('x_ynf_gender','ilike', ynf_gender_raw)]"/>
                    </t>
                    <t t-if="ynf_brand_raw">
                        <t t-set="ynf_domain"
                           t-value="ynf_domain + [('x_ynf_brand','ilike', ynf_brand_raw)]"/>
                    </t>
                    <t t-if="ynf_family_raw">
                        <t t-set="ynf_domain"
                           t-value="ynf_domain + [('x_ynf_family','ilike', ynf_family_raw)]"/>
                    </t>
                    <t t-set="ynf_order"
                       t-value="ynf_sort_raw or 'website_sequence asc, id desc'"/>
                    <t t-set="ynf_products"
                       t-value="request.env['product.template'].sudo().search(ynf_domain, order=ynf_order, limit=48)"/>
                    <t t-set="ynf_total_count"
                       t-value="request.env['product.template'].sudo().search_count(ynf_domain)"/>
                </t>
                <t t-else="">
                    <t t-set="ynf_products" t-value="products"/>
                    <t t-set="ynf_total_count"
                       t-value="request.env['product.template'].sudo().search_count([('is_published','=', True), ('sale_ok','=', True)])"/>
                </t>

                <!-- ============ HEADER ============ -->
                <header class="ynf-mfd2-shop-head">
                    <div class="ynf-mfd2-shop-head-inner">
                        <span class="ynf-mfd2-eyebrow">
                            <t t-esc="ynf_total_count"/>
                            <t t-if="ynf_total_count == 1"> fragrance in catalog</t>
                            <t t-else=""> fragrances in catalog</t>
                        </span>
                        <h1 class="ynf-mfd2-shop-title">Fragrances</h1>
                        <p class="ynf-mfd2-shop-sub">Curated dupes &amp; designer-rivalling Arabian houses.</p>
                    </div>
                </header>

                <!-- ============ STICKY FILTERS WRAPPER ============ -->
                <div class="ynf-mfd2-shop-filters">

                    <!-- Gender chips -->
                    <div class="ynf-mfd2-shop-chiprow" role="group" aria-label="Gender filter">
                        <span class="ynf-mfd2-shop-chiprow-label">Gender</span>
                        <div class="ynf-mfd2-shop-chiprow-track">
                            <t t-set="ynf_genders" t-value="[
                                ('', 'All'),
                                ('men', 'Men'),
                                ('women', 'Women'),
                                ('unisex', 'Unisex'),
                            ]"/>
                            <t t-foreach="ynf_genders" t-as="g">
                                <t t-set="_g_val" t-value="g[0]"/>
                                <t t-set="_g_label" t-value="g[1]"/>
                                <t t-set="_g_active" t-value="ynf_gender_raw.lower() == _g_val"/>
                                <t t-set="_g_query" t-value="{
                                    'ynf_gender': _g_val or None,
                                    'ynf_brand':  ynf_brand_raw or None,
                                    'ynf_family': ynf_family_raw or None,
                                    'order':      ynf_sort_raw or None,
                                }"/>
                                <a t-att-href="keep('/shop', **_g_query)"
                                   t-attf-class="ynf-mfd2-chip #{_g_active and 'ynf-mfd2-chip-active' or ''}"
                                   t-att-aria-pressed="'true' if _g_active else 'false'"
                                   rel="nofollow">
                                    <span class="ynf-mfd2-chip-label" t-esc="_g_label"/>
                                </a>
                            </t>
                        </div>
                    </div>

                    <!-- Brand chips (sourced from read_group on x_ynf_brand) -->
                    <t t-set="ynf_brand_rows"
                       t-value="request.env['product.template'].sudo().read_group(
                           [('x_ynf_brand', '!=', False), ('x_ynf_brand', '!=', ''), ('is_published','=', True)],
                           ['x_ynf_brand'], ['x_ynf_brand'],
                           orderby='x_ynf_brand_count desc', limit=14
                       )"/>
                    <div class="ynf-mfd2-shop-chiprow" role="group" aria-label="Brand filter">
                        <span class="ynf-mfd2-shop-chiprow-label">Brand</span>
                        <div class="ynf-mfd2-shop-chiprow-track">
                            <!-- "All" chip -->
                            <t t-set="_all_active" t-value="not ynf_brand_raw"/>
                            <t t-set="_all_query" t-value="{
                                'ynf_gender': ynf_gender_raw or None,
                                'ynf_brand':  None,
                                'ynf_family': ynf_family_raw or None,
                                'order':      ynf_sort_raw or None,
                            }"/>
                            <a t-att-href="keep('/shop', **_all_query)"
                               t-attf-class="ynf-mfd2-chip #{_all_active and 'ynf-mfd2-chip-active' or ''}"
                               t-att-aria-pressed="'true' if _all_active else 'false'"
                               rel="nofollow">
                                <span class="ynf-mfd2-chip-label">All</span>
                            </a>
                            <t t-foreach="ynf_brand_rows" t-as="b">
                                <t t-set="_b_name" t-value="b.get('x_ynf_brand') or ''"/>
                                <t t-if="_b_name">
                                    <t t-set="_b_active" t-value="ynf_brand_raw.lower() == _b_name.lower()"/>
                                    <t t-set="_b_query" t-value="{
                                        'ynf_gender': ynf_gender_raw or None,
                                        'ynf_brand':  _b_name,
                                        'ynf_family': ynf_family_raw or None,
                                        'order':      ynf_sort_raw or None,
                                    }"/>
                                    <a t-att-href="keep('/shop', **_b_query)"
                                       t-attf-class="ynf-mfd2-chip #{_b_active and 'ynf-mfd2-chip-active' or ''}"
                                       t-att-aria-pressed="'true' if _b_active else 'false'"
                                       rel="nofollow">
                                        <span class="ynf-mfd2-chip-label" t-esc="_b_name"/>
                                    </a>
                                </t>
                            </t>
                        </div>
                    </div>

                    <!-- Family chips (mood) -->
                    <t t-set="ynf_family_rows"
                       t-value="request.env['product.template'].sudo().read_group(
                           [('x_ynf_family', '!=', False), ('x_ynf_family', '!=', ''), ('is_published','=', True)],
                           ['x_ynf_family'], ['x_ynf_family'],
                           orderby='x_ynf_family_count desc', limit=10
                       )"/>
                    <div t-if="ynf_family_rows" class="ynf-mfd2-shop-chiprow" role="group" aria-label="Family filter">
                        <span class="ynf-mfd2-shop-chiprow-label">Family</span>
                        <div class="ynf-mfd2-shop-chiprow-track">
                            <t t-set="_all_f_active" t-value="not ynf_family_raw"/>
                            <t t-set="_all_f_query" t-value="{
                                'ynf_gender': ynf_gender_raw or None,
                                'ynf_brand':  ynf_brand_raw or None,
                                'ynf_family': None,
                                'order':      ynf_sort_raw or None,
                            }"/>
                            <a t-att-href="keep('/shop', **_all_f_query)"
                               t-attf-class="ynf-mfd2-chip #{_all_f_active and 'ynf-mfd2-chip-active' or ''}"
                               t-att-aria-pressed="'true' if _all_f_active else 'false'"
                               rel="nofollow">
                                <span class="ynf-mfd2-chip-label">All</span>
                            </a>
                            <t t-foreach="ynf_family_rows" t-as="f">
                                <t t-set="_f_name" t-value="f.get('x_ynf_family') or ''"/>
                                <t t-if="_f_name">
                                    <t t-set="_f_active" t-value="ynf_family_raw.lower() == _f_name.lower()"/>
                                    <t t-set="_f_query" t-value="{
                                        'ynf_gender': ynf_gender_raw or None,
                                        'ynf_brand':  ynf_brand_raw or None,
                                        'ynf_family': _f_name,
                                        'order':      ynf_sort_raw or None,
                                    }"/>
                                    <a t-att-href="keep('/shop', **_f_query)"
                                       t-attf-class="ynf-mfd2-chip #{_f_active and 'ynf-mfd2-chip-active' or ''}"
                                       t-att-aria-pressed="'true' if _f_active else 'false'"
                                       rel="nofollow">
                                        <span class="ynf-mfd2-chip-label" t-esc="_f_name"/>
                                    </a>
                                </t>
                            </t>
                        </div>
                    </div>

                    <!-- Sort row -->
                    <div class="ynf-mfd2-shop-sortrow" role="group" aria-label="Sort">
                        <span class="ynf-mfd2-shop-sortrow-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="4" y1="6" x2="20" y2="6"/>
                                <line x1="4" y1="12" x2="14" y2="12"/>
                                <line x1="4" y1="18" x2="9"  y2="18"/>
                            </svg>
                        </span>
                        <t t-set="ynf_sorts" t-value="[
                            ('', 'Featured'),
                            ('list_price asc',  'Price up'),
                            ('list_price desc', 'Price down'),
                            ('create_date desc', 'Newest'),
                        ]"/>
                        <t t-foreach="ynf_sorts" t-as="s">
                            <t t-set="_s_val" t-value="s[0]"/>
                            <t t-set="_s_label" t-value="s[1]"/>
                            <t t-set="_s_active"
                               t-value="(_s_val == '' and not ynf_sort_raw) or (ynf_sort_raw == _s_val)"/>
                            <t t-set="_s_query" t-value="{
                                'ynf_gender': ynf_gender_raw or None,
                                'ynf_brand':  ynf_brand_raw or None,
                                'ynf_family': ynf_family_raw or None,
                                'order':      _s_val or None,
                            }"/>
                            <a t-att-href="keep('/shop', **_s_query)"
                               t-attf-class="ynf-mfd2-shop-sortbtn #{_s_active and 'is-active' or ''}"
                               rel="nofollow">
                                <span t-esc="_s_label"/>
                            </a>
                        </t>
                    </div>
                </div>

                <!-- ============ GRID ============ -->
                <section class="ynf-mfd2-shop-section">
                    <t t-if="ynf_products and len(ynf_products) > 0">
                        <div class="ynf-mfd2-shop-grid">
                            <t t-foreach="ynf_products" t-as="product">
                                <div class="ynf-mfd2-shop-grid-cell">
                                    <t t-call="ynf_storefront.ynf_mfd2_card">
                                        <t t-set="product" t-value="product"/>
                                    </t>
                                </div>
                            </t>
                        </div>

                        <!-- Pagination: only render the native pager when our
                             chip filters aren't active (controller pager
                             reflects the unfiltered list). -->
                        <t t-if="not ynf_filter_active">
                            <div class="ynf-mfd2-shop-pager">
                                <t t-call="website.pager"/>
                            </div>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="ynf-mfd2-shop-empty">
                            <t t-call="ynf_storefront.ynf_mfd2_empty_state">
                                <t t-set="title">No fragrances match those filters</t>
                                <t t-set="body">Try removing a filter, or browse the full catalog.</t>
                                <t t-set="cta_label">Reset filters</t>
                                <t t-set="cta_href">/shop</t>
                            </t>
                        </div>
                    </t>
                </section>

            </div>
        </xpath>
    </template>

</odoo>
