<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ynf_tiktok_shop" model="ir.module.category">
        <field name="name">TikTok Shop</field>
        <field name="sequence">55</field>
    </record>

    <record id="group_tiktok_shop_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_ynf_tiktok_shop"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_tiktok_shop_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_ynf_tiktok_shop"/>
        <field name="implied_ids" eval="[(4, ref('group_tiktok_shop_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
