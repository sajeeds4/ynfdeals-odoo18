<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ynf_tiktok_product_map_list" model="ir.ui.view">
        <field name="name">ynf.tiktok.product.map.list</field>
        <field name="model">ynf.tiktok.product.map</field>
        <field name="arch" type="xml">
            <list>
                <field name="account_id"/>
                <field name="product_id"/>
                <field name="internal_sku"/>
                <field name="tiktok_product_id"/>
                <field name="tiktok_sku_id"/>
                <field name="status"/>
                <field name="last_odoo_qty"/>
                <field name="last_inventory_sync_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ynf_tiktok_product_map_form" model="ir.ui.view">
        <field name="name">ynf.tiktok.product.map.form</field>
        <field name="model">ynf.tiktok.product.map</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="account_id"/>
                        <field name="product_id"/>
                        <field name="tiktok_product_id"/>
                        <field name="tiktok_sku_id"/>
                        <field name="tiktok_category_id"/>
                        <field name="status"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ynf_tiktok_product_maps" model="ir.actions.act_window">
        <field name="name">Product Maps</field>
        <field name="res_model">ynf.tiktok.product.map</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
