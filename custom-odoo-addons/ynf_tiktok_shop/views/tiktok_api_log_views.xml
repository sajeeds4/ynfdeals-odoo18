<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ynf_tiktok_api_log_list" model="ir.ui.view">
        <field name="name">ynf.tiktok.api.log.list</field>
        <field name="model">ynf.tiktok.api.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="create_date"/>
                <field name="account_id"/>
                <field name="operation"/>
                <field name="method"/>
                <field name="path"/>
                <field name="status_code"/>
                <field name="ok"/>
                <field name="error"/>
            </list>
        </field>
    </record>

    <record id="view_ynf_tiktok_api_log_form" model="ir.ui.view">
        <field name="name">ynf.tiktok.api.log.form</field>
        <field name="model">ynf.tiktok.api.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <field name="account_id"/>
                        <field name="operation"/>
                        <field name="method"/>
                        <field name="path"/>
                        <field name="status_code"/>
                        <field name="ok"/>
                        <field name="error"/>
                    </group>
                    <group string="Request">
                        <field name="request_json" nolabel="1"/>
                    </group>
                    <group string="Response">
                        <field name="response_json" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ynf_tiktok_api_logs" model="ir.actions.act_window">
        <field name="name">API Logs</field>
        <field name="res_model">ynf.tiktok.api.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
