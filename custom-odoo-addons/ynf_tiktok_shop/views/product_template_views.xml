<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_tiktok_shop" model="ir.ui.view">
        <field name="name">product.template.form.tiktok.shop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="TikTok Shop Sync" name="ynf_tiktok_shop">
                    <group>
                        <field name="x_ynf_tiktok_account_id"/>
                        <field name="x_ynf_tiktok_product_id" readonly="1"/>
                        <field name="x_ynf_tiktok_sku_id" readonly="1"/>
                        <field name="x_ynf_tiktok_listing_status"/>
                        <field name="x_ynf_tiktok_last_push_at" readonly="1"/>
                    </group>
                    <button name="action_tiktok_push_inventory" type="object" string="Push Inventory to TikTok"
                        class="btn-primary" groups="ynf_tiktok_shop.group_tiktok_shop_manager"/>
                    <button name="action_tiktok_open_maps" type="object" string="View Product Maps"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
