<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ynf_tiktok_category_map_list" model="ir.ui.view">
        <field name="name">ynf.tiktok.category.map.list</field>
        <field name="model">ynf.tiktok.category.map</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="account_id"/>
                <field name="name"/>
                <field name="tiktok_category_id"/>
                <field name="tiktok_category_name"/>
                <field name="is_leaf"/>
            </list>
        </field>
    </record>

    <record id="action_ynf_tiktok_category_maps" model="ir.actions.act_window">
        <field name="name">Category Maps</field>
        <field name="res_model">ynf.tiktok.category.map</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
