<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================
         Reusable inline icon set (stroke 1.7) — matches the design's <Icon>.
         Usage: <t t-call="ynf_perfume_website.icon"><t t-set="name" t-value="'bag'"/></t>
         =================================================================== -->
    <template id="icon" name="YNF Icon">
        <t t-set="size" t-value="size or 22"/>
        <t t-set="sw" t-value="sw or 1.7"/>
        <svg t-att-width="size" t-att-height="size" viewBox="0 0 24 24" fill="none"
             t-att-stroke="color or 'currentColor'" t-att-stroke-width="sw"
             stroke-linecap="round" stroke-linejoin="round" class="y-ico">
            <t t-if="name == 'bag'"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></t>
            <t t-elif="name == 'search'"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></t>
            <t t-elif="name == 'heart'"><path d="M12 20s-7-4.4-7-9.5A3.8 3.8 0 0 1 12 7a3.8 3.8 0 0 1 7-2.5C19 10.6 12 20 12 20Z"/></t>
            <t t-elif="name == 'plus'"><path d="M12 5v14M5 12h14"/></t>
            <t t-elif="name == 'arrowR'"><path d="M4 12h15M13 6l6 6-6 6"/></t>
            <t t-elif="name == 'shield'"><path d="M12 3l7 3v6c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6l7-3Z"/><path d="M9 12l2 2 4-4"/></t>
            <t t-elif="name == 'truck'"><path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z"/><circle cx="7" cy="17" r="1.6"/><circle cx="17.5" cy="17" r="1.6"/></t>
            <t t-elif="name == 'spark'"><path d="M12 3l1.6 5.4L19 10l-5.4 1.6L12 17l-1.6-5.4L5 10l5.4-1.6L12 3Z"/></t>
            <t t-elif="name == 'star'"><path d="M12 4l2.3 5 5.5.4-4.2 3.6 1.3 5.4L12 16.9 7.1 18.4l1.3-5.4L4.2 9.4 9.7 9 12 4Z"/></t>
            <t t-elif="name == 'play'"><circle cx="12" cy="12" r="9"/><path d="M10 8.5l6 3.5-6 3.5Z" t-att-fill="color or 'currentColor'"/></t>
            <t t-elif="name == 'live'"><circle cx="12" cy="12" r="3.2" t-att-fill="color or 'currentColor'" stroke="none"/><path d="M7 7a7 7 0 0 0 0 10M17 7a7 7 0 0 1 0 10"/></t>
            <t t-else=""><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></t>
        </svg>
    </template>

    <!-- ===================================================================
         Luxury product card — used by homepage rails/grids.
         `product` is a product.template record. Links to its native /shop URL,
         so the PDP, pricing, variants & cart stay 100% Odoo.
         =================================================================== -->
    <template id="product_card" name="YNF Product Card">
        <t t-set="urgent" t-value="product.ynf_is_trending"/>
        <article class="y-card"
                 t-attf-onclick="window.location.href='#{product.website_url}'">
            <div class="y-card__stage">
                <t t-if="product.ynf_has_image()">
                    <img class="y-card__img"
                         t-att-src="'/web/image/product.template/%s/image_512' % product.id"
                         t-att-alt="product.name" loading="lazy" decoding="async"/>
                </t>
                <t t-else="">
                    <!-- Branded flacon fallback for products without a photo -->
                    <t t-set="tint" t-value="product.ynf_flacon_tint()"/>
                    <div class="y-flacon" t-attf-style="--f1:#{tint[0]}; --f2:#{tint[1]}">
                        <span class="y-flacon__cap"/>
                        <span class="y-flacon__body">
                            <span class="y-flacon__name" t-esc="product.name"/>
                            <span class="y-flacon__house" t-esc="product.ynf_display_brand or ''"/>
                        </span>
                    </div>
                </t>
                <!-- deal / status badges -->
                <t t-set="ynf_low" t-value="product.ynf_low_stock()"/>
                <t t-set="disc" t-value="product.ynf_discount()"/>
                <t t-if="disc['has']">
                    <span class="y-card__badge"><span class="y-tag y-tag--sale">-<t t-esc="disc['pct']"/>%</span></span>
                </t>
                <t t-elif="product.ynf_is_bestseller">
                    <span class="y-card__badge"><span class="y-tag y-tag--hot">Bestseller</span></span>
                </t>
                <t t-elif="product.ynf_is_new">
                    <span class="y-card__badge"><span class="y-tag y-tag--navy">New</span></span>
                </t>
                <t t-if="ynf_low">
                    <span class="y-card__badge y-card__badge--br"><span class="y-tag y-tag--soft">Only <t t-esc="ynf_low"/> left</span></span>
                </t>
            </div>
            <div class="y-card__body">
                <div class="y-card__brand" t-esc="product.ynf_display_brand or ''"/>
                <div class="y-card__name" t-esc="product.name"/>
                <div class="y-card__sub">
                    <span t-if="product.ynf_volume" t-esc="product.ynf_volume"/>
                    <span t-if="product.ynf_display_gender" class="y-card__gender">· <t t-esc="dict(men='Men', women='Women', unisex='Unisex').get(product.ynf_display_gender, '')"/></span>
                </div>
                <!-- price block: sale price + MSRP strikethrough + % off -->
                <div class="y-card__pricerow">
                    <span class="y-card__price">
                        <span t-field="product.list_price"
                              t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                    </span>
                    <t t-if="disc['has']">
                        <span class="y-card__msrp">
                            <span t-esc="'$%.2f' % disc['compare']"/>
                        </span>
                        <span class="y-card__save">Save <t t-esc="disc['pct']"/>%</span>
                    </t>
                </div>
                <button type="button" class="y-card__cart" t-att-data-ynf-add="product.id">
                    <t t-call="ynf_perfume_website.icon"><t t-set="name" t-value="'bag'"/><t t-set="size" t-value="15"/><t t-set="color" t-value="'#fff'"/></t>
                    Add to cart
                </button>
            </div>
        </article>
    </template>

    <!-- Section header partial: eyebrow + title + optional "view all" -->
    <template id="section_head" name="YNF Section Head">
        <div class="y-sechead y-rev">
            <div>
                <div class="y-eyebrow" t-esc="eyebrow"/>
                <h2 class="y-h-section" t-esc="title"/>
            </div>
            <t t-if="view_all_url">
                <a class="y-viewall" t-att-href="view_all_url">View all →</a>
            </t>
        </div>
    </template>
</odoo>
