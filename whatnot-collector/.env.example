WHATNOT_STREAM_URL=https://www.whatnot.com/live/STREAM_ID
WHATNOT_EMAIL=
WHATNOT_PASSWORD=
DB_PATH=./data/whatnot.db
POSTGRES_SIDECAR_ENABLED=1
POSTGRES_SIDECAR_DSN=postgresql://user:password@localhost:5432/whatnot
POSTGRES_SIDECAR_SCHEMA=sqlite_mirror
DB_PRIMARY_DOMAIN_SETTINGS=postgres
DB_PRIMARY_DOMAIN_REVIEWS=postgres
DB_PRIMARY_DOMAIN_EMPLOYEES=postgres
DB_PRIMARY_DOMAIN_IN_HOUSE=postgres
DB_PRIMARY_DOMAIN_INVENTORY=postgres
DB_PRIMARY_INVENTORY_PRODUCTS=postgres
DB_PRIMARY_INVENTORY_AUDIT=postgres
DB_PRIMARY_INVENTORY_MOVEMENTS=postgres
DB_PRIMARY_DOMAIN_COMPANY=postgres
DB_PRIMARY_COMPANY_CUSTOMERS=postgres
DB_PRIMARY_COMPANY_SESSIONS=postgres
DB_PRIMARY_COMPANY_LOTS=postgres
DB_PRIMARY_COMPANY_PENDING=postgres
DB_PRIMARY_COMPANY_RESULTS=postgres
DB_PRIMARY_COMPANY_ORDERS=postgres
DB_PRIMARY_DOMAIN_EVENTS=postgres
DB_PRIMARY_INGEST_STREAMS=postgres
DB_PRIMARY_INGEST_STREAM_MERGE=postgres
DB_PRIMARY_INGEST_EVENTS=postgres
DB_PRIMARY_INGEST_FAILED=postgres
DB_PRIMARY_INGEST_USERS=postgres
DB_PRIMARY_INGEST_LOTS=postgres
DB_PRIMARY_DOMAIN_ANALYTICS=postgres
EVENTS_DB_READ_BACKEND=postgres
EVENTS_DB_VALIDATE_READS=1
COLLECTOR_SQLITE_FALLBACK_ENABLED=0
ALLOW_SQLITE_RUNTIME=0
DB_DUAL_WRITE_SETTINGS=0
DB_DUAL_WRITE_REVIEWS=0
DB_DUAL_WRITE_EMPLOYEES=0
DB_DUAL_WRITE_IN_HOUSE=0
DB_DUAL_WRITE_INVENTORY=0
DB_DUAL_WRITE_COMPANY=0
DB_DUAL_WRITE_EVENTS=0
DB_DUAL_WRITE_ANALYTICS=0
DB_VALIDATE_WRITE_SETTINGS=1
DB_VALIDATE_WRITE_REVIEWS=1
DB_VALIDATE_WRITE_EMPLOYEES=1
DB_VALIDATE_WRITE_IN_HOUSE=1
DB_VALIDATE_WRITE_INVENTORY=1
DB_VALIDATE_WRITE_COMPANY=1
DB_VALIDATE_WRITE_EVENTS=1
DB_VALIDATE_WRITE_ANALYTICS=1
HEADLESS=true
POLL_INTERVAL_MS=250
COOKIES_PATH=./www.whatnot.com_cookies.json
WHATNOT_SESSION_ID=1

# Dashboard security
DASHBOARD_AUTH_REQUIRED=1
DASHBOARD_HTTPS_ONLY=0
DASHBOARD_HSTS_ENABLED=0
DASHBOARD_JWT_SECRET=replace-with-64-byte-url-safe-secret
DASHBOARD_POS_TOKEN_PEPPER=replace-with-independent-64-byte-url-safe-secret
DASHBOARD_POS_TOKEN_TTL_DAYS=30
DASHBOARD_TOTP_ENCRYPTION_KEY=replace-with-fernet-key
DASHBOARD_API_BEARER_BYPASS_ENABLED=0
DASHBOARD_API_BEARER_BYPASS_IP_ALLOWLIST=127.0.0.1,::1
API_SECRET_KEY=replace-with-automation-only-secret
DASHBOARD_RATE_LIMIT_LOGIN=8/minute
DASHBOARD_RATE_LIMIT_DIAGNOSTICS=60/minute
DASHBOARD_RATE_LIMIT_PUBLIC_TOKEN=120/minute
DASHBOARD_RATE_LIMIT_API=600/minute
DASHBOARD_CSP=default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self'; connect-src 'self' https: wss:; font-src 'self' data: https://fonts.gstatic.com; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# TikTok Shop Partner Center integration
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_SERVICE_ID=
TIKTOK_SHOP_REDIRECT_URI=
TIKTOK_SHOP_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key-or-long-random-secret
TIKTOK_SHOP_AUTHORIZE_BASE_URL=https://services.us.tiktokshop.com
TIKTOK_SHOP_AUTH_BASE_URL=https://auth.tiktok-shops.com
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK_SHOP_TOKEN_URL=https://auth.tiktok-shops.com/api/v2/token/get
TIKTOK_SHOP_REFRESH_URL=https://auth.tiktok-shops.com/api/v2/token/refresh
TIKTOK_SHOP_TARGET_IDC=alisg

# Google Sheets backup for TikTok Go Live sessions.
# Share the spreadsheet with the service account email as Editor.
GOOGLE_SHEETS_BACKUP_SPREADSHEET_URL=
GOOGLE_SHEETS_BACKUP_SPREADSHEET_ID=
GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

# MedusaJS website ecommerce integration.
# Medusa is only for normal website ecommerce. FastAPI/Postgres remains the
# source of truth for inventory, live auctions, fulfillment, and analytics.
MEDUSA_INTEGRATION_ENABLED=0
MEDUSA_BASE_URL=http://127.0.0.1:9000
MEDUSA_ADMIN_API_TOKEN=
MEDUSA_INTEGRATION_SECRET=replace-with-shared-medusa-fastapi-secret
MEDUSA_STORE_CURRENCY_CODE=usd
MEDUSA_SYNC_PAGE_SIZE=100
MEDUSA_STOCK_LOCATION_NAME=YNF Operations Inventory
